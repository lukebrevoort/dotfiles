# ===========================================================================
# Bash login profile — runs once at login
# Equivalent of .bash_profile / .profile
# ===========================================================================

# ------------------------------------------------------------------
# Homebrew shellenv (login-only)
# ------------------------------------------------------------------
if [[ -x "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# ------------------------------------------------------------------
# Conda (login / initialization)
# ------------------------------------------------------------------
if [[ -f "/opt/anaconda3/etc/profile.d/conda.sh" ]]; then
    source "/opt/anaconda3/etc/profile.d/conda.sh"
fi

# ------------------------------------------------------------------
# OrbStack tools
# ------------------------------------------------------------------
if [[ -f "$HOME/.orbstack/shell/init.bash" ]]; then
    source "$HOME/.orbstack/shell/init.bash" 2>/dev/null || true
fi

# ------------------------------------------------------------------
# OPAM
# ------------------------------------------------------------------
if [[ -r "$HOME/.opam/opam-init/init.sh" ]]; then
    source "$HOME/.opam/opam-init/init.sh" >/dev/null 2>/dev/null || true
fi

if [[ -r "$HOME/.bashrc" ]]; then
    source "$HOME/.bashrc"
fi
