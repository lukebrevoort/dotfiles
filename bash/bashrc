# ===========================================================================
# Bash configuration — sourced by both interactive and login shells
# Equivalent to dotfiles/fish/config.fish
# ===========================================================================

export EDITOR=nvim
export VISUAL=nvim

# ------------------------------------------------------------------
# PATH / Homebrew
# ------------------------------------------------------------------
if [[ -x "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# ------------------------------------------------------------------
# User-local scripts
# ------------------------------------------------------------------
if [[ -d "$HOME/.local/bin" ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# ------------------------------------------------------------------
# Profile / identity file
# ------------------------------------------------------------------
if [[ -f "$HOME/.config/dotfiles/profile" ]]; then
    export DOTFILES_PROFILE
    IFS= read -r DOTFILES_PROFILE < "$HOME/.config/dotfiles/profile"
fi
: "${DOTFILES_PROFILE:=personal}"
export DOTFILES_PROFILE

# ------------------------------------------------------------------
# Load profile environment variables (security filtered)
# ------------------------------------------------------------------
allowed_prefixes=(OPENCODE_ NOTION_ ANTHROPIC_ OPENAI_ GITHUB_ GEMINI_ MCP_ API_ TAVILY_)

for local_env in \
    "$HOME/.config/dotfiles/$DOTFILES_PROFILE.env" \
    "$HOME/.env.opencode"
do
    [[ -f "$local_env" ]] || continue

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" || "$line" == '#'* ]] && continue
        line="${line#export }"

        if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
            var_name="${BASH_REMATCH[1]}"
            var_val="${BASH_REMATCH[2]}"
            is_allowed=0

            for pfx in "${allowed_prefixes[@]}"; do
                [[ "$var_name" == "$pfx"* ]] && { is_allowed=1; break; }
            done

            if (( is_allowed )); then
                var_val="${var_val%\"}"
                var_val="${var_val#\"}"
                var_val="${var_val%\'}"
                var_val="${var_val#\'}"
                export "$var_name=$var_val"
            fi
        fi
    done < "$local_env"
done

if [[ -r "$HOME/.config/dotfiles/local.sh" ]]; then
    source "$HOME/.config/dotfiles/local.sh"
fi

# ------------------------------------------------------------------
# Starship prompt
# ------------------------------------------------------------------
if [[ $- == *i* ]] && command -v starship &>/dev/null; then
    eval "$(starship init bash)"
fi

# ------------------------------------------------------------------
# Zoxide (smart cd)
# ------------------------------------------------------------------
if [[ $- == *i* ]] && command -v zoxide &>/dev/null; then
    eval "$(zoxide init bash)"
fi

# ------------------------------------------------------------------
# lazygit alias
# ------------------------------------------------------------------
if command -v lazygit &>/dev/null; then
    alias lg='lazygit'
fi

# ------------------------------------------------------------------
# Portable bash functions
# ------------------------------------------------------------------
bash_funcs_dir="$HOME/.config/bash/functions"
if [[ -d "$bash_funcs_dir" ]]; then
    for func_file in "$bash_funcs_dir"/*.bash; do
        [[ -f "$func_file" ]] && source "$func_file"
    done
fi

# ------------------------------------------------------------------
# fzf — Fish-like fuzzy search (Ctrl+R history, Ctrl+T files, Alt+C cd)
# ------------------------------------------------------------------
if [[ $- == *i* ]] && command -v fzf &>/dev/null; then
    # Use fd for faster file search (respects .gitignore)
    if command -v fd &>/dev/null; then
        export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
        export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"
    fi

    # Use bat for previews
    if command -v bat &>/dev/null; then
        export FZF_CTRL_T_OPTS="--preview 'bat -n --color=always {}'"
    fi

    # Preview directory trees with eza/ls
    if command -v eza &>/dev/null; then
        export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"
    fi

    # fzf color scheme (Gruvbox-inspired)
    export FZF_DEFAULT_OPTS=" \
    --color=bg:-1,fg:-1,hl:#fabd2f \
    --color=bg+:#3c3836,fg+:#ebdbb2,hl+:#fabd2f \
    --color=info:#83a598,prompt:#fabd2f,pointer:#83a598 \
    --color=marker:#b8bb26,spinner:#b8bb26,header:#83a598"

    # Source fzf key bindings and completion
    source /opt/homebrew/opt/fzf/shell/completion.bash 2>/dev/null
    source /opt/homebrew/opt/fzf/shell/key-bindings.bash 2>/dev/null
fi

# ------------------------------------------------------------------
# eza — modern ls replacement (like Fish's ls, but better)
# ------------------------------------------------------------------
if command -v eza &>/dev/null; then
    alias ls='eza --group-directories-first --icons'
    alias ll='eza --group-directories-first --icons -la'
    alias la='eza --group-directories-first --icons -a'
    alias lt='eza --group-directories-first --icons -T'
    alias l1='eza --group-directories-first --icons -1'
    alias tree='eza --group-directories-first --icons -T --git-ignore'
fi

# ------------------------------------------------------------------
# bat — modern cat replacement with syntax highlighting
# ------------------------------------------------------------------
if command -v bat &>/dev/null; then
    alias cat='bat --paging=never'
    alias catt='bat --style=plain'
fi

# ------------------------------------------------------------------
# Fish-like quality-of-life aliases
# ------------------------------------------------------------------
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

alias grep='grep --color=auto'
alias df='df -h'
alias du='du -h'
alias free='free -m'
alias mkdir='mkdir -p'
alias cp='cp -iv'
alias mv='mv -iv'

# ------------------------------------------------------------------
# Directory navigation helpers (like Fish)
# ------------------------------------------------------------------
alias d='dirs -v'
for i in {1..9}; do
    alias "$i"="cd +$i"
done

# ------------------------------------------------------------------
# bash-completion@2 — programmable completion (takes many defaults)
# ------------------------------------------------------------------
if [[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]]; then
    source /opt/homebrew/etc/profile.d/bash_completion.sh
fi

# ------------------------------------------------------------------
# ble.sh — Fish-like syntax highlighting & autosuggestions for Bash
# Requires bash 4.0+ (loads automatically on bash 5.x from Homebrew)
# ------------------------------------------------------------------
if [[ $- == *i* && -f ~/.local/share/blesh/ble.sh && "${BASH_VERSINFO[0]}" -ge 4 ]]; then
    source -- ~/.local/share/blesh/ble.sh --attach=none
    if type -t ble-attach >/dev/null 2>&1; then
        ble-attach
    fi
fi
